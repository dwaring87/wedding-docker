#
# Settings for the Nuxt Site
#

# Host and Port (within the docker container) binding for the site
HOST=0.0.0.0
PORT=3000

# URL that the Nuxt server uses to connect to the CMS
#
# The CMS is only accessed via the backend API server of the website,
# so the docker container name can be used as the host here
NUXT_DIRECTUS_URL=http://wedding-cms:8055

# API cache length (seconds)
#
# This changes the amount of time information from the CMS is cached
# by the Nuxt server.  Increasing this will mean fewer API requests
# between the site and the CMS, which could increase performance, but
# means updates will be slower to appear.  This does not apply to the 
# invite / guest information and the alert, which is not cached at all.
NUXT_CACHE_API=15
NUXT_CACHE_PHOTOS=300
