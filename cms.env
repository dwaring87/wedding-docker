#
# DIRECTUS / CMS SETTINGS
# For additional variables, see: https://directus.io/docs/configuration/intro
#

# Host and Port binding (within the docker container) for the CMS
HOST=0.0.0.0
PORT=8055

# Secret used by the CMS for signing, set to a random value
SECRET=

# Public URL for the CMS
# This will be used by Directus when generating full URLs to pages, photos, etc
# and should be externally accessible.
PUBLIC_URL=http://localhost:8055

# Credentials for the initial admin user
# You can create additional users on the CMS website
ADMIN_EMAIL=me@example.com
ADMIN_PASSWORD=password
ADMIN_FIRST_NAME=First
ADMIN_LAST_NAME=Last

# DB used by the CMS
# This SQLite database contains the initial DB structure
DB_CLIENT=sqlite3
DB_FILENAME=/directus/database/database.sqlite

# Data cache settings
CACHE_ENABLED=false

# Email Settings for sending transactional emails from the CMS
EMAIL_TRANSPORT=smtp
EMAIL_FROM=email@example.com
EMAIL_SMTP_HOST=mail.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=email@example.com
EMAIL_SMTP_PASSWORD=email

# RSVP Email Notifications
#
# Send an email to the specfied addresses when an 
# RSVP has been updated through the website.
# This requires the email env vars to be setup.
#
# Set to true to enable email notifications or false to disable
RSVP_NOTIFICATIONS_ENABLE=true
# Enter a comma separated list of email address, default: admin email
RSVP_NOTIFICATIONS_RECIPIENTS=
